# Copy this file to .env.local and fill in your values.
# If these are missing, the app falls back to in-memory mock data + an offline
# AI persona so the UI still renders end-to-end.

# ───── Supabase ─────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only — keep secret.
SUPABASE_SERVICE_ROLE_KEY=

# ───── AI providers (set at least one) ─────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# Optional global override — forces every persona to use one provider regardless of
# its declared default. Useful when you only have one key configured.
# JARVIS_AI_PROVIDER=openai     # or "anthropic"

# ───── Market data ─────
# Yahoo Finance is the free default and needs no key. Switch later by setting:
# JARVIS_MARKET_PROVIDER=polygon
# POLYGON_API_KEY=

# ───── Bank sync (Plaid) ─────
# Sign up at https://dashboard.plaid.com — start in Sandbox, flip to
# production once Link works end-to-end.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox             # sandbox | production
# Required for OAuth institutions (Bank of America forces OAuth).
# Sandbox: http://localhost:3000/banks/return is OK.
# Production: Plaid requires HTTPS — use ngrok (https://....ngrok-free.app/banks/return)
#   or your deployed URL; register the exact URL in Plaid → Allowed redirect URIs.
PLAID_REDIRECT_URI=
# Webhook URL Plaid pings on transaction/holdings updates. In dev:
# https://<your-subdomain>.ngrok-free.app/api/banks/webhook
PLAID_WEBHOOK_URL=

# 32-byte hex key used to AES-256-GCM-encrypt Plaid access tokens at rest.
# Generate ONCE with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# DO NOT rotate without re-encrypting existing tokens.
JARVIS_ENCRYPTION_KEY=
