# Copy this file to .env.local and fill in your Supabase project values.
# If these are missing, the app falls back to in-memory mock data so the UI still renders.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Only used server-side for privileged inserts/updates. Keep this secret.
SUPABASE_SERVICE_ROLE_KEY=
